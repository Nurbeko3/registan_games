# Optional Supabase cloud save. Leave unset to run fully offline.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Keep Arena online rooms locked unless cloud/authority is explicitly enabled.
# With ARENA_AUTHORITY_STATUS_URL set, the health endpoint must return:
#   { "ok": true, "authority": "arena" }
# Without a status URL, this allows the existing Supabase Realtime arena mode.
NEXT_PUBLIC_ARENA_MULTIPLAYER_AUTHORITY=
ARENA_AUTHORITY_ENABLED=false
ARENA_AUTHORITY_STATUS_URL=
ARENA_AUTHORITY_STATUS_TOKEN=
